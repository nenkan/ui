{
  "name": "@nenkan/ui",
  "version": "0.28.1",
  "description": "Reusable React components following Nenkan styles",
  "exports": "./dist/index.js",
  "private": true,
  "scripts": {
    "build": "node ./scripts/clean.js && babel src --out-dir dist --copy-files --source-maps --extensions \".ts,.tsx\" && node ./scripts/build.js",
    "build:watch": "nodemon --watch src --exec npm run build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "release": "npm run build && cd dist && npm publish"
  },
  "type": "module",
  "author": "nenkan",
  "homepage": "https://www.nen-kan.com/ui",
  "license": "MIT",
  "dependencies": {
    "classnames": "^2.5.1",
    "react": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nenkan/ui.git"
  },
  "source": true,
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@nenkan/css": "0.25.1",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
